# バックエンドの環境変数サンプル。実値は書かず、各自 .env を作成して設定する。
# .env は .gitignore で除外済み(秘密情報は Git に登録しない)。

# データベース接続(docker-compose 使用時は host=db)
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=teamlink_development
DB_NAME_TEST=teamlink_test

# CORS 許可オリジン(フロントの開発サーバ)
FRONTEND_ORIGIN=http://localhost:5173
